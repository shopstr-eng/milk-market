# Database connection string
# For local development with docker-compose:
DATABASE_URL=postgresql://milkmarket:milkmarket@localhost:5432/milkmarket

# Controls whether Testcontainers-based integration tests run.
# Set to exactly `1` to enable tests guarded by RUN_TESTCONTAINERS (requires Docker).
# Example: RUN_TESTCONTAINERS=1
#
# When enabled, some integration tests will start a real Postgres container
# via Testcontainers. Only enable in environments with Docker available.
RUN_TESTCONTAINERS=0

# Required for MCP agent onboarding when Milk Market stores encrypted nsec values
MCP_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Optional: override the public base URL used in MCP onboarding responses
# NEXT_PUBLIC_BASE_URL=https://milkmarket.example

# from request headers if NEXT_PUBLIC_BASE_URL is not set
# MCP_ALLOWED_HOSTS=milkmarket.example,api.milkmarket.example

# Optional: trust X-Forwarded-For for rate limiting only when requests always
# pass through a reverse proxy that appends the real client IP.
# TRUST_PROXY_HEADERS=true
#
# Alternative: trust forwarded headers only from these direct proxy IPs.
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# For production, use your actual database URL:
# DATABASE_URL=postgresql://user:password@host:port/database

# --- Self-host (single-tenant) mode ------------------------------------------
# For a Wrangler/lifetime seller running their OWN private copy of Milk Market.
# When MM_SELF_HOST is on, the public marketplace + discovery routes are hidden,
# the Pro entitlement is unlocked ONLY for MM_SELF_HOST_PUBKEY, and card
# checkout uses the seller's own standard Stripe account (direct charges).
# Leave MM_SELF_HOST unset/0 for the normal hosted multi-tenant platform.
# These can also be supplied via a milk-market.config.json file (env wins).
#
# MM_SELF_HOST=1
# Owner pubkey (64-char hex or npub1...). The entitlement bypass is scoped to
# exactly this pubkey and fails closed if unset.
# MM_SELF_HOST_PUBKEY=
# Owner storefront slug; the proxy serves it at the site root "/".
# MM_SELF_HOST_SLUG=
# Optional comma-separated relay / Blossom lists (informational + exported).
# MM_SELF_HOST_RELAYS=wss://relay.damus.io,wss://nos.lol
# MM_SELF_HOST_BLOSSOM_SERVERS=https://blossom.primal.net
# Offer card checkout via the seller's own Stripe account. Defaults to on when
# STRIPE_SECRET_KEY is set; set to 0 to force-disable the card option.
# MM_SELF_HOST_OWN_STRIPE=1
# Public repo to pull code updates from (defaults to the canonical repo).
# MM_SELF_HOST_UPSTREAM_REPO=https://github.com/shopstr-eng/milk-market
# Optional override for the config file path (defaults to ./milk-market.config.json).
# MM_SELF_HOST_CONFIG_PATH=
